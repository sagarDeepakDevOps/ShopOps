ENVIRONMENT=local
DEBUG=false
PROJECT_NAME=ShopOps
API_V1_STR=/api/v1
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256
DATABASE_URL=postgresql+asyncpg://shopops:shopops@postgres:5432/shopops
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=
FRONTEND_URL_LOCAL=http://localhost:3000
FRONTEND_URL_STAGING=https://staging.shopops.example
FRONTEND_URL_PRODUCTION=https://shopops.example
RATE_LIMIT_DEFAULT=100/minute
OTEL_ENABLED=true
OTEL_SERVICE_NAME=shopops-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
LOG_LEVEL=INFO
LOGSTASH_ENABLED=true
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
